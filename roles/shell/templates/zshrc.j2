# {{ ansible_managed }}
# =============================================================================
# .zshrc - Managed by Ansible
# =============================================================================

# Path to Oh My Zsh
export ZSH="$HOME/.oh-my-zsh"

# Theme
ZSH_THEME="{{ zsh_theme }}"

# Plugins
plugins=(
{% for plugin in zsh_plugins %}
  {{ plugin }}
{% endfor %}
)

source $ZSH/oh-my-zsh.sh

# -----------------------------------------------------------------------------
# Version managers
# -----------------------------------------------------------------------------
# rbenv
eval "$(rbenv init -)"

# pyenv
eval "$(pyenv init -)"

# nvm
export NVM_DIR="$HOME/.nvm"
[ -s "$NVM_DIR/nvm.sh" ] && \. "$NVM_DIR/nvm.sh"
[ -s "$NVM_DIR/bash_completion" ] && \. "$NVM_DIR/bash_completion"

# -----------------------------------------------------------------------------
# PATH
# -----------------------------------------------------------------------------
{% for p in shell_extra_paths %}
export PATH="{{ p }}:$PATH"
{% endfor %}

{% if rust_toolchain | length > 0 %}
# Rust (installed via rustup)
export PATH="$HOME/.cargo/bin:$PATH"
{% endif %}

{% if enable_postgresql_paths | default(false) %}
# PostgreSQL client tools (libpq — installed via postgresql@17)
export PATH="/opt/homebrew/opt/libpq/bin:$PATH"
{% endif %}

# User scripts
export PATH="$PATH:$HOME/scripts"

# pnpm
export PNPM_HOME="$HOME/Library/pnpm"
case ":$PATH:" in
  *":$PNPM_HOME:"*) ;;
  *) export PATH="$PNPM_HOME:$PATH" ;;
esac

# -----------------------------------------------------------------------------
# Environment variables
# -----------------------------------------------------------------------------
{% for key, value in shell_env_vars.items() %}
export {{ key }}="{{ value }}"
{% endfor %}

{% if enable_postgresql_paths | default(false) %}
# Compiler flags for PostgreSQL (needed for native gem/package builds against libpq)
export LDFLAGS="-L/opt/homebrew/opt/libpq/lib"
export CPPFLAGS="-I/opt/homebrew/opt/libpq/include"
{% endif %}

# -----------------------------------------------------------------------------
# Secrets (API keys, tokens - never committed to version control)
# -----------------------------------------------------------------------------
[ -f "$HOME/.secrets" ] && source "$HOME/.secrets"

# -----------------------------------------------------------------------------
# Custom user configuration (not managed by Ansible)
# -----------------------------------------------------------------------------
# Add your personal aliases, functions, and customizations to ~/.zshrc.local
# This file is sourced last and will override any Ansible-managed settings
[ -f "$HOME/.zshrc.local" ] && source "$HOME/.zshrc.local"
